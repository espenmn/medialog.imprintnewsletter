<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" i18n:domain="medialog.imprintnewsletter" metal:use-macro="context/main_template/macros/master">
  <body>
    <metal:content-core fill-slot="content">
      <metal:block define-macro="content">
        <div class="card">
          <div class="card-body">

            <h1 i18n:translate="heading_subscribe_unsubscribe">Aanmelden/afmelden voor e-maillijst</h1>

            <form method="post" action="${context/absolute_url}/@@subscribe">
              <div class="form-group xcard">

                <input id="inputEmail" class="form-control" type="email" name="email" 
                      tal:attributes="value request/email|request/form/email|None"
                      placeholder="Voer uw e-mailadres in" i18n:attributes="placeholder email_placeholder;"
                       required />

                <hr/>

                <!-- Language selector -->
                <!-- <label for="language" i18n:translate="label_language">Language</label> -->
                <select id="language" name="language" class="form-control" with="20" i18n:attributes="title language_title;">
                  <option value="" i18n:translate="lang_none">Choose language</option>
                  <option value="nl" i18n:translate="lang_dutch">Dutch</option>
                  <option value="en" i18n:translate="lang_english">English</option>
                  <option value="fr" i18n:translate="lang_french">French</option>
                  <option value="de" i18n:translate="lang_german">German</option>
                </select>

                <div><hr/></div>
                

                <button class="button btn btn-primary" type="submit" name="form.subscribed" i18n:translate="button_subscribe">Aanmelden</button>
                <button class="button btn btn-secondary" type="submit" name="form.unsubscribe" i18n:translate="button_unsubscribe">Afmelden</button>

              </div>
            </form>
          </div>
        </div>

        <style>
          .above-content-wrapper {padding-top: 2rem; margin-top: 2rem;}
          .border-1 { border: 1px dotted silver; padding: 2rem; background: white }
          .outer-wrapper { background: whitesmoke }
          .card { margin-top: 3rem; margin-bottom: 2rem; max-width: 45rem; }
          #language {width: 205px}
        </style>
      </metal:block>
    </metal:content-core>
  </body>
</html>



 