<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" i18n:domain="medialog.imprintnewsletter" metal:use-macro="context/main_template/macros/master">
  <body>
    <metal:content-core fill-slot="content">
      <metal:block define-macro="content">
        <div class="card">
          <div class="card-body">

            <h1 i18n:translate="heading_subscribe_unsubscribe">Aanmelden/afmelden voor e-maillijst</h1>

            <form method="post" action="${context/absolute_url}/@@manage-subscribers" enctype="multipart/form-data">
              <div class="form-group xcard">

                <textarea id="inputEmail" class="form-control" name="email"  
                  tal:attributes="value request/email|request/form/email|None"
                  placeholder="Voer een lijst met e-mailadressen in, één per regel" i18n:attributes="placeholder email_list_placeholder;"></textarea>
                <hr/>
                <!-- Language selector -->
                <!-- <label for="language" i18n:translate="label_language">Language</label> -->
                <select id="language" name="language" class="form-control" i18n:attributes="title language_title;">
                  <option value="" i18n:translate="lang_none">Choose language</option>
                  <option value="nl" i18n:translate="lang_dutch">Dutch</option>
                  <option value="en" i18n:translate="lang_english">English</option>
                  <option value="fr" i18n:translate="lang_french">French</option>
                  <option value="de" i18n:translate="lang_german">German</option>
                </select>
                <div>
                  <hr/>
                </div>
                <button class="button btn btn-primary" type="submit" name="form.subscribed" i18n:translate="button_subscribe">Aanmelden</button>
                <button class="button btn btn-secondary" type="submit" name="form.unsubscribe" i18n:translate="button_unsubscribe">Afmelden</button>
              </div>
              <hr/>
              <div class="form-group upload">
                <!-- File upload -->
                <h3 i18n:translate="heading_excelbuttons">Excel</h3>
                <input type="file" id="excel_file" name="excel_file" accept=".xlsx" class="form-control" />
                <hr/>
                <button class="button btn btn-primary" type="submit"   name="form.button_importexcel" i18n:translate="button_importexcel">Excel import</button>
                <button class="button btn btn-secondary" type="submit" name="form.button_exportexcel" i18n:translate="button_exportexcel">Excel export</button>
              </div>
            </form>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h3 i18n:translate="heading_current_subscribers">Huidige abonnees</h3>
            <table class="listing pat-datatables">
              <thead>
                <tr>
                  <th i18n:translate="">E-mail</th>
                  <th i18n:translate="">Taal</th>
                  <th i18n:translate="">Aangemeld</th>
                </tr>
              </thead>
              <tbody>
                <tr tal:repeat="subscriber python: view.subscribers()">
                  <td tal:content="python: subscriber['email']">E-mail</td>
                  <td tal:content="python: subscriber['language']">Taal</td>
                  <td tal:content="python: subscriber['created'].Date()">Aangemeld</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <div class="card-body">
            <h3 i18n:translate="heading_current_subscribers">Unsubscribed</h3>
            <table class="listing pat-datatables">
              <thead>
                <tr>
                  <th i18n:translate="">Email</th>
                  <th i18n:translate="">Language</th>
                  <th i18n:translate="">Afgemeld</th>
                </tr>
              </thead>
              <tbody>
                <tr tal:repeat="subscriber python: view.unsubscribers()">
                  <td tal:content="python: subscriber['email']">Email</td>
                  <td tal:content="python: subscriber['language']">Lang</td>
                  <td tal:content="python: subscriber['created'].Date()">Aangemeld</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <style>
          .above-content-wrapper {padding-top: 2rem;}
          .border-1 { border: 1px dotted silver; padding: 2rem; background: white }
          .outer-wrapper { background: whitesmoke }
          .card { margin-top: 3rem; margin-bottom: 2rem; max-width: 45rem; }
          .form-group.upload {   margin-top: 3rem !important }
        </style>

      </metal:block>
    </metal:content-core>
  </body>
</html>


 